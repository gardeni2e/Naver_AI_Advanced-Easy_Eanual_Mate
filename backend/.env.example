# CLOVA Studio
CLOVA_API_KEY=
CLOVA_CHAT_MODEL_ID=HCX-005
CLOVA_API_BASE=https://clovastudio.stream.ntruss.com
CLOVA_EMBED_V2_URL=https://clovastudio.stream.ntruss.com/v1/api-tools/embedding/v2

# CLOVA OCR
CLOVA_OCR_API_URL=
CLOVA_OCR_SECRET_KEY=

# CLOVA Voice
CLOVA_VOICE_CLIENT_ID=
CLOVA_VOICE_CLIENT_SECRET=
CLOVA_VOICE_API_URL=https://naveropenapi.apigw.ntruss.com/tts-premium/v1/tts
CLOVA_VOICE_SPEAKER=nara

# Gemini manual link recommendation
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# YouTube video recommendation
YOUTUBE_API_KEY=

# RAG Config
CHUNK_SIZE=500
CHUNK_OVERLAP=80
TOP_K=4
CLOVA_EMBED_RETRY_COUNT=4
CLOVA_EMBED_RETRY_BASE_DELAY=2.0
CLOVA_EMBED_REQUEST_INTERVAL=0.25
MOCK_WHEN_NO_API_KEY=true

# Storage
UPLOAD_DIR=app/data/uploads
OCR_IMAGE_DIR=app/data/ocr_images
AUDIO_DIR=app/data/audio
VECTOR_STORE_DIR=app/data/vector_store
SQLITE_DB_PATH=app/data/app.db
